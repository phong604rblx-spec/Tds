task.spawn(function()
    local plr = game.Players.LocalPlayer

function click()
    local tool = plr.Character and plr.Character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
        tool:Deactivate()
    end
end

-- call không block
function call()
    task.spawn(function()
        game:GetService("ReplicatedStorage")
            :WaitForChild("Shared")
            :WaitForChild("DataStreams")
            :WaitForChild("FishBiting")
            :InvokeServer()
    end)
end

-- UI
local gui = Instance.new("ScreenGui", plr:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local btn = Instance.new("TextButton", gui)
btn.Size = UDim2.new(0,120,0,40)
btn.Position = UDim2.new(0,10,0,10)
btn.Text = "OFF"

local on = false

btn.MouseButton1Click:Connect(function()
    on = not on
    btn.Text = on and "ON" or "OFF"

    if on then
        task.spawn(function()
            while on do
                click()
                task.wait(0.6)

                call() 
                task.wait(0.6)

                click()
                task.wait(0.3)

                click()
                task.wait(0.5)

                click()
                
                click()
                task.wait(0.6)

                click()
                task.wait(0.2)
            end
        end)
    end
end)
    end)

